}

/* Pricing Section */
.pricing {
    padding: 80px 0;
    background: linear-gradient(135deg, #0F1419 0%, #1a2332 100%);
    text-align: center;
}

.pricing h2 {
    text-align: center;
    color: var(--primary-gold);
}

.pricing-card {
    background: rgba(212, 165, 116, 0.1);
    border: 2px solid var(--primary-gold);
    padding: 3rem;
    border-radius: 12px;
    max-width: 500px;
    margin: 2rem auto;
}

.price-tag {
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary-gold);
    margin-bottom: 1rem;
}

.currency {
    font-size: 1.5rem;
}

.amount {
    font-size: 3rem;
}

.original-price {
    color: var(--text-muted);
    margin-bottom: 0.5rem;
}

.discount {
    color: var(--accent-orange);
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 1rem;
}

.pricing-card .description {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
}

.delivery {
    color: var(--accent-orange);
    margin-top: 1.5rem;
}

/* CTA Buttons */
.cta-primary {
    display: inline-block;
    background: var(--primary-gold);
    color: var(--primary-dark);
    padding: 15px 40px;
    border: none;
    border-radius: 6px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.cta-primary:hover {
    background: var(--accent-orange);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(212, 165, 116, 0.2);
}

/* Final CTA Section */
.final-cta {
    padding: 60px 0;
    background: rgba(212, 165, 116, 0.05);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
}

.final-cta h2 {
    text-align: center;
    color: var(--primary-gold);
}

/* Footer */
footer {
    padding: 3rem 0;
    background: rgba(212, 165, 116, 0.02);
    border-top: 1px solid var(--border-color);
    text-align: center;
    color: var(--text-muted);
}

/* Responsive Design */
@media (max-width: 768px) {
    h1 { font-size: 2rem; }
    h2 { font-size: 1.8rem; }
    
    .hero {
        padding: 50px 0;
    }
    
    .hero h1 {
        font-size: 2rem;
    }
    
    .hook {
        font-size: 1.1rem;
    }
    
    .pain-grid,
    .solution-grid,
    .deliverables-list {
        grid-template-columns: 1fr;
    }
    
    .pricing-card {
        padding: 2rem;
    }
    
    .price-tag {
        font-size: 2rem;
    }
    
    .amount {
        font-size: 2rem;
    }
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

section {
    animation: fadeInUp 0.8s ease-out;
}
// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
        }
    });
});

// Track CTA clicks
document.querySelectorAll('.cta-primary').forEach(button => {
    button.addEventListener('click', function(e) {
        console.log('CTA clicked:', this.href);
        // Add your analytics code here
        // Example: gtag('event', 'cta_click', { url: this.href });
    });
});

// Intersection Observer for fade-in animations
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
        }
    });
}, { threshold: 0.1 });

document.querySelectorAll('section').forEach(section => {
    section.style.opacity = '0';
    section.style.transform = 'translateY(20px)';
    section.style.transition = 'all 0.6s ease-out';
    observer.observe(section);
});
