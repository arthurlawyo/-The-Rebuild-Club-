.solution-step {
    background: rgba(212, 165, 116, 0.05);
    border: 1px solid var(--border-color);
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
    transition: all 0.3s ease;
}

.solution-step:hover {
    background: rgba(212, 165, 116, 0.1);
    border-color: var(--primary-gold);
}

.step-number {
    display: inline-block;
    width: 50px;
    height: 50px;
    background: var(--primary-gold);
    color: var(--primary-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.solution-step h4 {
    color: var(--primary-gold);
    margin-bottom: 1rem;
}

/* Deliverables Section */
.deliverables {
    padding: 80px 0;
    background: #0F1419;
}

.deliverables h2 {
    text-align: center;
    color: var(--primary-gold);
}

.deliverables-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
}

.item {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(212, 165, 116, 0.05);
    border-left: 3px solid var(--primary-gold);
